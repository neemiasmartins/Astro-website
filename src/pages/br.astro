---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header-br.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config';
import Section from '../components/Section.astro';
---

<!DOCTYPE html>
<html lang="pt-Br">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="sitemap" href="/sitemap-index.xml" />




	</head>
	<body>
	
		<Header title={SITE_TITLE} />
		<main style="margin: auto 0;">

			
			<div class="profile">

 			 	<!-- linha de cima: nome + subtítulo + foto -->
  				<div class="profile-top">

    			<div class="profile-title">
     				 <h1 class="neemias">Neemias Martins</h1>
      					<h3 class="subtitle">Professor de Matemática na UFV</h3>
						<a href="https://neemias.org" class="subtitle">neemias.org</a>
   				 </div>

   				 <div class="profile-img">
      				<a href="https://www.instagram.com/neemias.math">
        			<img src="/img/profile.jpg" alt="Photo Neemias" >
     				 </a>
   				 </div>

 				 </div>

				 <div class="profile-bottom">
			Olá! Sou professor na <a href="/blog/2025-08-04">Universidade Federal de Viçosa</a>. Doutor em matemática pelo <a href="https://www.ime.unicamp.br/">Imecc</a> / Unicamp, e mestre e bacharel em Matemática pela UFV. <a href="/resume.pdf"  class="morelink">Ver currículo &#8250;</a> </p>

			<p>
